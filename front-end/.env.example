# ============================================================
# .env.example
# Copiá este archivo a .env y completá los valores.
# NUNCA commitees .env (ya está en .gitignore de Expo).
# ============================================================

# URL base del backend Spring Boot.
# Según la plataforma de desarrollo:
#   Emulador Android        → http://10.0.2.2:8080
#   Simulador iOS / web     → http://localhost:8080
#   Dispositivo físico      → http://<IP-de-tu-máquina>:8080  (ej: http://192.168.1.50:8080)
EXPO_PUBLIC_API_URL=http://10.0.2.2:8080

# Activar datos de prueba en lugar de llamadas reales al backend.
# true  → el app usa mock data (comportamiento actual de desarrollo)
# false → el app llama a la API real (requiere backend corriendo)
EXPO_PUBLIC_USE_MOCKS=true
